# ---- Secrets & local config ----
.claude/*.local.md
.env
.env.*
!.env.example
*.local.json
*.pem
*.key
credentials.json

# ---- Maintainer-only workspace (not distributed) ----
# Agents / skills / instructions / audit reports scoped to the collate
# maintainer working inside this repo with Claude Code or Codex. These are
# not part of the plugin surface users install.
.claude/agents/
.claude/skills/
.claude/CLAUDE.md
.codex/skills/
.codex/AGENTS.md
docs/audit/
docs/superpowers/
reports/

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# ---- Test / real-user data (do NOT publish) ----
# User sample manuscripts live under text/; extend here for any other scratch
# area where PDFs are dropped in to try the pipeline. Anything published must go
# under examples/ with the explicit sample.* filenames below.
text/
!text/.gitkeep
test/
!test/.gitkeep
examples/output/
examples/tmp/
*.prep/
*.ocr/
*.ocr_cache/

# ---- Binary / large media ----
*.pdf
!examples/sample.pdf
*.docx
!examples/sample.docx
*.zip
*.tar.gz
*.7z
*.iso
*.dmg

# ---- OS ----
.DS_Store
Thumbs.db

# ---- Editors ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Logs & runtime ----
*.log
logs/
tmp/
temp/
*.pid
